{
  "compilerOptions":{
    "target":"ES2022",
    "lib":["dom","dom.iterable","esnext"],
    "strict":true,
    "jsx":"preserve",
    "module":"esnext",
    "moduleResolution":"bundler",
    "resolveJsonModule":true,
    "isolatedModules":true,
    "noEmit":true,
    "incremental":true
  },
  "include":["**/*.ts","**/*.tsx"],
  "exclude":["node_modules"]
}